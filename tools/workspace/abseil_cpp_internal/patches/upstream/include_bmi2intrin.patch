[abseil-cpp] Include preffered intrinsics header

Cherry-picking
https://github.com/abseil/abseil-cpp/commit/d851fdd768b27c02b3fb786fd0987faddd279ece.

GCC 15 rejects including this header directly, as a private implementation.
Drake uses BMI2 when amd64v3 packages are enabled, which is by default on most
Ubuntu 26.04 builds.

--- absl/container/internal/raw_hash_set.h
+++ absl/container/internal/raw_hash_set.h
@@ -226,7 +226,7 @@
 #endif

 #ifdef __BMI2__
-#include <bmi2intrin.h>
+#include <immintrin.h>
 #endif  // __BMI2__

 namespace absl {
