# -*- bazel -*-

load("@drake_uv//:requirements.bzl", uv_requirement = "requirement")
load("@drake//tools/skylark:py.bzl", "py_binary")

py_binary(
    name = "gen",
    srcs = ["implib-gen.py"],
    deps = [uv_requirement("lief")],
    data = glob(["arch/**", "implib/**"], allow_empty = False),
    main = "implib-gen.py",
    python_version = "PY3",
    srcs_version = "PY3",
    visibility = ["//visibility:public"],
)

exports_files(["drake_repository_metadata.json"])
