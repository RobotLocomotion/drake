# -*- python -*-

load(":vars.bzl", "LIBDIR")

licenses(["notice"])  # X11

cc_library(
    name = "yaml_cpp",
    hdrs = glob(["include/yaml-cpp/**/*.h"]),
    includes = ["include"],
    linkopts = [
        "-L" + LIBDIR,
        "-Wl,-rpath," + LIBDIR,
        "-lyaml-cpp",
    ],
    visibility = ["//visibility:public"],
)
