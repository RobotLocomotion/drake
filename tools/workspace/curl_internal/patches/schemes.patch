[curl_internal] Disable all schemes except http

This avoids linker errors for undefined schemes.

Reasoning for not upstreaming this patch: Drake-specific build flavor.

--- lib/protocol.c
+++ lib/protocol.c
@@ -1461,6 +1461,12 @@
    present. */
 const struct Curl_scheme *Curl_getn_scheme(const char *scheme, size_t len)
 {
+#if 1  // Replaced by drake
+  if ((len == 4) && curl_strnequal(scheme, "http", 4)) {
+    return &Curl_scheme_http;
+  }
+  return NULL;
+#else
   /* table generated by schemetable.c:
      1. gcc schemetable.c && ./a.out
      2. check how small the table gets
@@ -1523,6 +1529,7 @@
       return h;
   }
   return NULL;
+#endif
 }
 
 const struct Curl_scheme *Curl_get_scheme(const char *scheme)
