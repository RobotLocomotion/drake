#!/bin/bash

set -euo pipefail

usage () {
    cat <<eof
Usage:
 kcov_tool clean
 kcov_tool merge [OUTPUT-DIR]

Manage the code coverage data generated by bazel kcov and kcov_everything
configurations.

The clean subcommand removes all the kcov data stored in the workspace from
prior invocations.

The merge subcommand finds all existing kcov data in the workspace and merges
it into OUTPUT-DIR. If OUTPUT-DIR does not exist, it will be created.

eof
}

die () {
    echo Error: "$@"
    echo
    usage
    exit 1
}

find_kcov_data () {
    find $(bazel info bazel-testlogs) -type d -name kcov
}

clean () {
    find_kcov_data | xargs rm -rf
}

merge () {
    [[ "$#" -ge 1 ]] || die missing argument OUTPUT-DIR
    DATA=$(find_kcov_data)
    [[ -n "$DATA" ]] || die no kcov data to merge
    kcov --merge "$1" $(find_kcov_data)
}

[[ "$#" -ge 1 ]] || die missing subcommand

VERB=$1
[[ "$VERB" =~ ^(clean|merge)$ ]] || die unknown subcommand: "$VERB"

shift
$VERB "$@"

