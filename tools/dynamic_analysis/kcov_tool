#!/usr/bin/env python3

"""
Manage the code coverage data generated by bazel kcov and kcov_everything
configurations. See instructions here:
https://drake.mit.edu/bazel.html?highlight=kcov#kcov
"""

import argparse
import glob
import shutil
import subprocess
import os
import sys


def get_workspace():
    """Return the bazel workspace directory that this file is in, or raise an
    exception.
    """
    def is_workspace(apath):
        return os.path.exists(os.path.join(apath, "WORKSPACE"))

    apath = os.path.abspath(os.path.dirname(__file__))
    while not is_workspace(apath):
       apath = os.path.dirname(apath)
    assert is_workspace(apath)
    return apath

WORKSPACE = get_workspace()


def log(*args):
    """"Print args to stderr."""
    print(*args, file=sys.stderr)


def find_kcov_data():
    """Find the kcov data of individual test runs within the tree linked by
    bazel-testlogs.
    """
    return glob.glob(os.path.join(WORKSPACE, 'bazel-testlogs/**/kcov'),
                     recursive=True)


def clean(args):
    """Implement the clean subcommand."""
    for d in find_kcov_data():
        shutil.rmtree(d)


def do_merge(output_dir, strict=True, verbose=False):
    """Merge the kcov data of individual test runs into output_dir. If strict is
    True, fail if there is no kcov data available. If verbose is True, log
    detailed information about inputs and outputs.
    """
    if verbose:
        log(f"do_merge({output_dir}, strict={strict}, verbose={verbose})")
    dirs = find_kcov_data()
    if verbose:
        log("BEGIN found kcov dirs")
        log('\n'.join(dirs))
        log("END found kcov dirs")
    if not dirs:
        if strict:
            sys.exit("Error: no kcov data to merge")
        else:
            return

    # Smooth over kcov location change from Bionic to Focal.
    newenv = os.environ.copy()
    newenv['PATH'] = "/opt/kcov/35/bin:" + newenv['PATH']

    cmd = ['kcov', '--merge', output_dir] + dirs
    subprocess.run(cmd, env=newenv)
    if verbose:
        merged_files = glob.glob(output_dir + '/**', recursive=True)
        log("BEGIN found kcov merged files")
        log('\n'.join(merged_files))
        log("END found kcov merged files")


def ci_merge(args):
    """Implement the ci_merge subcommand."""
    # TODO(rpoyner-tri): once all the machinery is merged, set strict to True.
    do_merge(os.path.join(WORKSPACE, "bazel-kcov"), strict=False)


def merge(args):
    """Implement the merge subcommand."""
    do_merge(args.output_dir)


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    subparsers = parser.add_subparsers(
        help='subcommand to run', dest='subcommand')
    subparsers.required = True

    parser_ci_merge = subparsers.add_parser(
        'ci_merge', help='like merge, but verbose, and always to bazel-kcov.'
        ' For now, succeeds even if no data is available; see #10617.')
    parser_ci_merge.set_defaults(func=ci_merge)

    parser_clean = subparsers.add_parser(
        'clean', help='remove all kcov data from the bazel-testlogs tree')
    parser_clean.set_defaults(func=clean)

    parser_merge = subparsers.add_parser(
        'merge',
        help='merge all kcov data from the bazel-testlogs tree to OUTPUT-DIR')
    parser_merge.add_argument(
        'output_dir', metavar='OUTPUT-DIR',
        help='output directory for merged kcov data;'
        ' if not existing it will be created.')
    parser_merge.set_defaults(func=merge)

    args = parser.parse_args()
    args.func(args)


if __name__ == '__main__':
    main()
