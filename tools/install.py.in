#!/usr/bin/env python

import argparse
import filecmp
import os
import shutil

subdirs = set()
installed_files = set()
prefix = None


def needs_install(src, dst):
    # Get canonical destination.
    dst_full = os.path.join(prefix, dst)

    # Check if destination exists.
    if not os.path.exists(dst_full):
        # Destination doesn't exist -> installation needed.
        return True

    # Check if files are different.
    if filecmp.cmp(src, dst_full, shallow=False):
        # Files are the same -> no installation needed.
        return False

    # File needs to be installed.
    return True


def install(src, dst):
    global subdirs, installed_files

    # Ensure destination subdirectory exists, creating it if necessary.
    subdir = os.path.dirname(dst)
    if subdir not in subdirs:
        subdir_full = os.path.join(prefix, subdir)
        if not os.path.exists(subdir_full):
            os.makedirs(subdir_full)
        subdirs.add(subdir)

    # Install file, if not up to date.
    if needs_install(src, dst):
        print("[Installing] %s" % dst)
        dst_full = os.path.join(prefix, dst)
        if os.path.exists(dst_full):
            os.remove(dst_full)
        shutil.copy2(src, dst_full)

    else:
        print("[Up to date] %s" % dst)

    installed_files.add(dst)


def clean(path, parents=[]):
    # Iterate over items in current path.
    for item in os.listdir(path):
        # Get full path.
        item_full = os.path.join(path, item)

        # Get "full" (root-relative) path as list.
        item_parts = parents + [item]

        if os.path.isdir(item_full):
            # Recurse into directories.
            clean(os.path.join(path, item), item_parts)

        elif os.path.isfile(item_full):
            # Get "full" path of file without install prefix.
            p = os.path.join(*item_parts)

            # Check if file is supposed to be installed, and delete it if not.
            if p not in installed_files:
                print("[Removing] %s" % p)
                os.remove(item_full)


def main(args):
    global prefix

    # Set up options.
    parser = argparse.ArgumentParser()
    parser.add_argument('prefix', type=str, help='Install prefix')
    parser.add_argument('--clean', dest='clean', action='store_true',
                        help='Remove extra files from install directory')
    args = parser.parse_args(args)

    # Get install prefix.
    prefix = args.prefix

    # Because Bazel executes us in a strange working directory and not the
    # working directory of the user's shell, enforce that the install
    # location is an absolute path so that the user is not surprised.
    if not os.path.isabs(prefix):
        import sys
        sys.stderr.write(
            "Install prefix must be an absolute path (got %r)\n"
            % prefix)
        sys.exit(1)

    # Execute the install actions.
    <<actions>>

    # Optionally remove "extra" files from install prefix.
    if args.clean:
        clean(prefix)


if __name__ == "__main__":
    import sys
    main(sys.argv[1:])
