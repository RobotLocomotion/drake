#!/bin/bash
#
# Install Drake prerequisites. This script is a small bash trampoline which
# first installs Python (if missing) and then uses Python for the remainder of
# the installation.

set -euo pipefail

# This script should be run as the normal user (i.e., `setup/install_prereqs`),
# not under sudo (i.e., not `sudo setup/install_prereqs`). On the other hand, if
# the normal user *is* the root user (e.g., inside Docker) then we allow it, or
# if sudo is being used to switch users (i.e., `sudo -u otheruser ...`) then we
# allow it. The only mistake we're trying to catch here is accidentally using
# `sudo` out of habit (since that's what Drake previously required).
if [[ "${EUID}" -eq 0 && -n "${SUDO_USER:+D}" ]]; then
  echo 'This script must NOT be run through sudo' >&2
  exit 1
fi

# ============================ Command line options ============================

sh_args=()
py_args=()
user_environment_only=0
while [ "${1:-}" != "" ]; do
  case "$1" in
    --user-environment-only)
      user_environment_only=1
      py_args+=("$1")
      ;;
    --verbose)
      py_args+=("$1")
      ;;
    *)
      sh_args+=("$1")
      py_args+=("$1")
      ;;
  esac
  shift
done

# =============================== Install Python ===============================

if [[ "${user_environment_only}" -eq 0 ]]; then
  if [[ "$(uname)" == "Darwin" ]]; then
    /bin/bash "${BASH_SOURCE%/*}/mac/install_prereqs.sh" "${sh_args[@]:0}"
  else
    if ! command -v python3 > /dev/null; then
      echo "Installing python3 ..." >&2
      maybe_sudo=
      if [[ "${EUID}" -ne 0 ]]; then
        maybe_sudo=sudo
      fi
      # XXX Obey --without-update.
      if ! ${maybe_sudo} apt-get -y install python3; then
        ${maybe_sudo} apt-get update || (sleep 30; apt-get update)
        ${maybe_sudo} apt-get -y install python3
      fi
    fi
  fi
fi

# ============================= Hand over to Python ============================

if [[ "$(uname)" == "Darwin" ]]; then
  # N.B. We need `${var:0}` here because macOS's older version of bash does not
  # seem to be able to cope with an empty array.
  exec $(brew --prefix)/bin/python3.14 -B "${BASH_SOURCE%/*}/install_prereqs.py" "${py_args[@]:0}"
else
  exec /usr/bin/python3 -B "${BASH_SOURCE%/*}/install_prereqs.py" "${py_args[@]}"
fi
