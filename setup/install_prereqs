#!/bin/bash
#
# Install Drake prerequisites.

set -euo pipefail

# This script should be run as the normal user (i.e., `setup/install_prereqs`),
# not under sudo (i.e., not `sudo setup/install_prereqs`). On the other hand, if
# the normal user *is* the root user (e.g., inside Docker) then we allow it, or
# if sudo is being used to switch users (i.e., `sudo -u otheruser ...`) then we
# allow it. The only mistake we're trying to catch here is accidentally using
# `sudo` out of habit (since that's what Drake previously required).
if [[ "${EUID}" -eq 0 && -n "${SUDO_USER:+D}" ]]; then
  echo 'This script must NOT be run through sudo' >&2
  exit 1
fi

# While we're halfway through rewriting our setup scripts to Python, the command
# line arguments need to go to specific helper scripts.
sh_args=()
py_args=()
user_environment_only=0
while [ "${1:-}" != "" ]; do
  case "$1" in
    --user-environment-only)
      user_environment_only=1
      py_args+=("$1")
      ;;
    --verbose)
      py_args+=("$1")
      ;;
    *)
      sh_args+=("$1")
      py_args+=("$1")
      ;;
  esac
  shift
done

# Call the helper scripts. The first one bootstraps Python if necessary; the
# second one uses the Python installed by the first one.
if [[ "$(uname)" == "Darwin" ]]; then
  # N.B. We need `${var:0}` throughout this section because macOS's older
  # version of bash does not seem to be able to cope with an empty array.
  if [[ "${user_environment_only}" -eq 0 ]]; then
    /bin/bash "${BASH_SOURCE%/*}/mac/install_prereqs.sh" "${sh_args[@]:0}"
  fi
  $(brew --prefix)/bin/python3.14 -B "${BASH_SOURCE%/*}/install_prereqs.py" "${py_args[@]:0}"
else
  if [[ "${user_environment_only}" -eq 0 ]]; then
    /bin/bash "${BASH_SOURCE%/*}/ubuntu/install_prereqs.sh" "${sh_args[@]}"
  fi
  /usr/bin/python3 -B "${BASH_SOURCE%/*}/install_prereqs.py" "${py_args[@]}"
fi
