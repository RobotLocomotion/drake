<?xml version="1.0"?>
<sdf version="1.6">
  <model name="Particle">
    <!-- Particle of mass m = 0.5 Kg and zero size. It can only move along the z
         axis. -->
    <link name="particle">
      <inertial>
        <pose>0 0 0.0 0 0 0</pose>
        <mass>0.5</mass>
        <!-- Inertia values are irrelevant for this case given there is a single
        prismatic joint that only allows the particle to move in the z axis,
        with no rotation. -->
        <inertia>
          <ixx>1.0e40</ixx>
          <iyy>1.0e40</iyy>
          <izz>1.0e40</izz>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyz>0</iyz>
        </inertia>
      </inertial>

      <visual name="visual">
        <pose>0.0 0.0 0.0 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.005</radius>
          </sphere>
        </geometry>
        <material>
          <diffuse>1 0 0 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <pose>0.0 0.0 0.0 0 0 0</pose>
        <geometry>
          <sphere>
            <radius>0.0</radius>
          </sphere>
        </geometry>
        <drake:proximity_properties>
          <drake:mu_dynamic>0.5</drake:mu_dynamic>
          <drake:mu_static>0.5</drake:mu_static>
        </drake:proximity_properties>
      </collision>
    </link>

    <!--
    <joint name="z_slider" type="prismatic">
      <parent>world</parent>
      <child>particle</child>
      <axis>
        <xyz>0.0 0.0 1.0</xyz>
        <limit>   
          <effort>0</effort>
        </limit>
      </axis>
    </joint>
-->
  </model>
</sdf>