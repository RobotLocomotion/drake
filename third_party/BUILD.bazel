# -*- python -*-

load("//tools/lint:lint.bzl", "add_lint_tests")

package(default_visibility = ["//visibility:public"])

exports_files(
    select({
        "@drake//tools/cc_toolchain:apple": ["net_sf_jchart2d/LICENSE"],
        "//conditions:default": [],
    }),
    licenses = ["restricted"],  # LGPL-3.0+
