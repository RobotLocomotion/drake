<sdf version='1.7'>
  <model name='parallel_linkage'>
    <!--

    This sdf file produces a model with the default parameters for a
    parallel four bar linkage.

    Diagram of the modeled 4-bar linkage:

    Links AB, BC, CD, and DA complete the closed kinematic chain. The diagram
    is of a planar chain in the X-Z plane.

    In this model link DA is the world and links AB and CD are parallel and
    have the same length. Points A and D are 2m apart.

    Link AB is canonically known as the "Crank" link.
    Link CD is canonically known as the "Rocker" link.
    Link BC is canonically known as the "Coupler" link.

    Joint A (CrankJoint) is a revolute joint on the Y axis between the world
    and the Crank link.
    Joint B (CrankCouplerJoint) is a revolute joint on the Y axis between the
    Crank and the CrankCoupler link.
    Joint D (RockerJoint) is a revolute joint on the Y axis between the world
    and the Rocker Link.
    Joint C (RockerCouplerJoint) is a revolute joint on the Y axis between the
    Rocker and the RockerCoupler link.

    Since closed kinematic chains are not currently supported, the coupler link
    is split in half at its midpoint, separating it into the "Crank" side link
    BE called the "CrankCoupler" and the "Rocker" side link EC called the
    "RockerCoupler". A frame is attached to each of these links, coincident
    at the midpoint of the link, E. These frames are used in the code to weld
    the links together with a LinearBushingRollPitchYaw ForceElement to
    approximate the links being welded.

                A                                             D
    + - - - - - + - - - - - - - - - - - - - - - - - - - - - - + - - - - - +
                |                                             |
                |                                             |
        (Crank) |                                             |  (Rocker)
          1m    |                                             |     1m
                |                                             |
                |         1m                      1m          |
                |   (CrankCoupler)    E     (RockerCoupler)   |
            B   + - - - - - - - - - - + - - - - - - - - - - - +  C
                                  (Coupler)
                                     2m

    -->

    <!-- Crank Side -->

    <link name='Crank'>
      <!-- The origin of the Crank frame is defined to be coincident with
           the origin of the x-z plane in the world frame. -->
      <pose>0 0.15 0 0 0 0</pose>
      <inertial>
        <pose>0 0 -0.5 0 0 0</pose>
        <mass>10</mass>
        <inertia>
          <!-- The inertia is based off the cylinder described in the
          Crank_visual tag: radius=0.05m length=1.1m mass=10kg -->
          <ixx>1.01458333</ixx><iyy>1.01458333</iyy><izz>0.0125</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='Crank_visual'>
        <pose>0 0 -0.5 0 0 0</pose>
        <geometry>
          <cylinder>
            <length>1.1</length>
            <radius>0.05</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>1 0 0 1</diffuse>
        </material>
      </visual>
      <!-- Visual showing the pin holding the Crank link to the world -->
      <visual name='Crank_pivot_visual'>
        <pose>0 0 0 1.57 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.01</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 1 0 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name='CrankJoint' type='revolute'>
      <child>Crank</child>
      <parent>world</parent>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <!-- No limit provided. sdformat defaults to -1, which we parse as
               an actuated joint. -->
        </limit>
        <dynamics>
          <damping>0.1</damping>
        </dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <link name='CrankCoupler'>
      <pose>0 0.25 -1 0 1.57 0</pose>
      <inertial>
        <pose>0 0 -0.5 0 0 0</pose>
        <mass>10</mass>
        <inertia>
          <!-- The inertia is based off the cylinder described in the
               CrankCoupler_visual tag: radius=0.05m length=1.05m mass=10kg -->
          <ixx>0.925</ixx><iyy>0.925</iyy><izz>0.0125</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='CrankCoupler_visual'>
        <pose>0 0 -0.475 0 0 0</pose>
        <geometry>
          <cylinder>
            <length>1.05</length>
            <radius>0.05</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 1 1</diffuse>
        </material>
      </visual>
      <!-- Visual showing the pin holding the CrankCoupler link to the Crank -->
      <visual name='CrankCoupler_pivot_visual'>
        <pose>0 -0.05 0 1.57 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.01</radius>
            <length>0.25</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 1 0 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name='CrankCouplerJoint' type='revolute'>
      <parent>Crank</parent>
      <child>CrankCoupler</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <!-- Drake parses a zero effort joint as an un-actuated joint. -->
          <effort>0</effort>
        </limit>
        <dynamics>
          <damping>0.1</damping>
        </dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <!-- Rocker Side -->

    <link name='Rocker'>
      <pose>-2 0.35 0 0 0 0</pose>
      <inertial>
        <pose>0 0 -0.5 0 0 0</pose>
        <mass>10</mass>
        <inertia>
          <!-- The inertia is based off the cylinder described in the
               Rocker_visual tag: radius=0.05m length=1.1m mass=10kg -->
          <ixx>1.01458333</ixx><iyy>1.01458333</iyy><izz>0.0125</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='Rocker_visual'>
        <pose>0 0 -0.5 0 0 0</pose>
        <geometry>
          <cylinder>
            <length>1.1</length>
            <radius>0.05</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>1 1 0 1</diffuse>
        </material>
      </visual>
      <!-- Visual showing the pin holding the Rocker link to the world -->
      <visual name='Rocker_pivot_visual'>
        <pose>0 0 0 1.57 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.01</radius>
            <length>0.15</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 1 0 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name='RockerJoint' type='revolute'>
      <child>Rocker</child>
      <parent>world</parent>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <!-- Drake parses a zero effort joint as an un-actuated joint. -->
          <effort>0</effort>
        </limit>
        <dynamics>
          <damping>0.1</damping>
        </dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <link name='RockerCoupler'>
      <pose>-2 0.25 -1 0 -1.57 0</pose>
      <inertial>
        <pose>0 0 -0.5 0 0 0</pose>
        <mass>10</mass>
        <inertia>
          <!-- The inertia is based off the cylinder described in the
               RockerCoupler_visual tag: radius=0.05m length=1.05m mass=10kg-->
          <ixx>0.925</ixx><iyy>0.925</iyy><izz>0.0125</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name='RockerCoupler_visual'>
        <pose>0 0 -0.475 0 0 0</pose>
        <geometry>
          <cylinder>
            <length>1.05</length>
            <radius>0.05</radius>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 0 1 1</diffuse>
        </material>
      </visual>
      <!-- Visual showing the pin holding the RockerCoupler link to the Rocker
       -->
      <visual name='RockerCoupler_pivot_visual'>
        <pose>0 0.05 0 1.57 0 0</pose>
        <geometry>
          <cylinder>
            <radius>0.01</radius>
            <length>0.25</length>
          </cylinder>
        </geometry>
        <material>
          <diffuse>0 1 0 1</diffuse>
        </material>
      </visual>
    </link>

    <joint name='RockerCouplerJoint' type='revolute'>
      <parent>Rocker</parent>
      <child>RockerCoupler</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <!-- Drake parses a zero effort joint as an un-actuated joint. -->
          <effort>0</effort>
        </limit>
        <dynamics>
          <damping>0.1</damping>
        </dynamics>
        <use_parent_model_frame>1</use_parent_model_frame>
      </axis>
    </joint>

    <!-- Two coincident frames at point E. One attached to each body on the
         two sides to be welded together -->

    <frame name="CrankCouplerWeld" attached_to="CrankCoupler">
      <pose relative_to="CrankCoupler">0 0 -1 0 0 0</pose>
    </frame>

    <frame name="RockerCouplerWeld" attached_to="RockerCoupler">
      <pose relative_to="RockerCoupler">0 0 -1 0 0 0</pose>
    </frame>

  </model>
</sdf>
