#!/bin/bash
# Execute the complete set of steps for a well-controlled benchmark experiment.

set -e -u -o pipefail

TARGET=//examples/multibody/cassie_benchmark:record_results
ME=$(readlink -f $0)
HERE=$(dirname $ME)

OUTPUT_DIR="$1"
shift

cd "$HERE"/../../..

./tools/performance/benchmark_tool conduct_experiment \
    $TARGET "$OUTPUT_DIR" -- "$@"
